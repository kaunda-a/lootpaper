---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import BackgroundEffects from "../components/layout/BackgroundEffects.astro";
import UuidGenerator from "../components/tools/UuidGenerator.astro";
import ThemeInit from "../components/ui/ThemeInit.astro";
import OfferBanner from "../components/ads/OfferBanner.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>UUID Generator — Lootpaper</title>
    <meta name="description" content="Generate UUID v4 and v1 identifiers instantly. Free, no signup." />
    <meta property="og:title" content="UUID Generator — Lootpaper" />
    <meta property="og:description" content="Generate UUID v4 and v1 identifiers" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://lootpaper.com/uuid-generator" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <ThemeInit />
    <ClientRouter />
  </head>
  <body class="bg-background text-foreground">
    <BackgroundEffects />
    <Header currentPath={Astro.url.pathname} />
    <main class="py-20">
      <div class="container">
        <div class="text-center mb-10">
          <span class="inline-flex h-7 items-center rounded-full border border-primary/20 bg-primary/8 px-3.5 text-xs font-medium text-primary mb-4">Tool</span>
          <h1 class="text-3xl lg:text-4xl font-bold tracking-tight mb-3"><span class="gradient-text">UUID Generator</span></h1>
          <p class="text-muted-foreground max-w-lg mx-auto">Generate UUID v4 and v1 identifiers instantly. Free, no signup.</p>
        </div>
        <OfferBanner />
        <UuidGenerator />
      </div>
    </main>
    <Footer />
  </body>
</html>