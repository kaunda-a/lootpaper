---
import "../../styles/global.css";
import { ClientRouter } from "astro:transitions";
import Header from "../../components/layout/Header.astro";
import Footer from "../../components/layout/Footer.astro";
import BackgroundEffects from "../../components/layout/BackgroundEffects.astro";
import BlogThumbnail from "../../components/blog/BlogThumbnail.astro";
import { getCollection } from "astro:content";
import ThemeInit from "../../components/ui/ThemeInit.astro";

const posts = await getCollection("blog");
const sorted = posts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
const featured = sorted[0];
const rest = sorted.slice(1);

function readingTime(body: string): string {
  const words = body.split(/\s+/).length;
  const minutes = Math.max(1, Math.round(words / 200));
  return `${minutes} min read`;
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Blog — Lootpaper</title>
    <meta name="description" content="Marketing tips, SEO guides, and resources for makers and indie hackers." />
    <meta property="og:title" content="Blog — Lootpaper" />
    <meta property="og:description" content="Marketing tips, SEO guides, and resources for makers." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <ThemeInit />
    <ClientRouter />
  </head>
  <body class="bg-background text-foreground">
    <BackgroundEffects />
    <Header currentPath="/blog" />

    <section class="py-20 text-center">
      <div class="container">
        <span class="inline-flex h-7 items-center rounded-full border border-primary/20 bg-primary/8 px-3.5 text-xs font-medium text-primary mb-6">Blog</span>
        <h1 class="text-4xl lg:text-5xl font-bold tracking-tight mb-3">Marketing <span class="gradient-text">Guides</span></h1>
        <p class="text-muted-foreground max-w-lg mx-auto text-lg">Practical tips on SEO, marketing tools, and growing your online presence as a maker or indie hacker.</p>
      </div>
    </section>

    {featured && (
      <section class="pb-10">
        <div class="container max-w-4xl">
          <a
            href={`/blog/${featured.id}`}
            class="group block rounded-2xl border border-border bg-card overflow-hidden card-hover glow-border"
          >
            <BlogThumbnail title={featured.data.title} size="lg" class="w-full" />
            <div class="p-8 lg:p-10">
              <div class="flex flex-wrap items-center gap-3 mb-3">
                <span class="inline-flex h-5 items-center rounded-full bg-primary/15 text-primary px-2.5 text-[10px] font-semibold uppercase tracking-wider">Latest</span>
                <time class="text-sm text-muted-foreground">{featured.data.pubDate.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}</time>
                <span class="text-sm text-muted-foreground">&middot;</span>
                <span class="text-sm text-muted-foreground">{readingTime(featured.body || "")}</span>
              </div>
              <h2 class="text-2xl lg:text-3xl font-bold tracking-tight mb-3 group-hover:text-primary transition-colors duration-200">{featured.data.title}</h2>
              <p class="text-muted-foreground leading-relaxed mb-5">{featured.data.description}</p>
              <div class="flex items-center gap-3">
                <div class="flex flex-wrap gap-1.5">
                  {featured.data.tags.slice(0, 3).map((tag) => (
                    <span class="inline-flex h-5 items-center rounded-full bg-primary/10 text-primary px-2.5 text-[10px] font-medium">{tag}</span>
                  ))}
                </div>
                <span class="text-sm font-medium text-primary group-hover:underline decoration-primary/30 underline-offset-4 ml-auto">Read article &rarr;</span>
              </div>
            </div>
          </a>
        </div>
      </section>
    )}

    <section class="pb-20">
      <div class="container max-w-4xl">
        {rest.length > 0 && (
          <>
            <div class="flex items-center gap-3 mb-8">
              <div class="h-px flex-1 bg-border" />
              <span class="text-xs font-semibold text-muted-foreground tracking-widest uppercase">More articles</span>
              <div class="h-px flex-1 bg-border" />
            </div>
            <div class="grid gap-6 md:grid-cols-2">
              {rest.map((post) => (
                <a
                  href={`/blog/${post.id}`}
                  class="group block rounded-xl border border-border bg-card overflow-hidden card-hover glow-border flex flex-col"
                >
                  <BlogThumbnail title={post.data.title} size="sm" class="w-full" />
                  <div class="p-5 flex flex-col flex-1">
                    <div class="flex flex-wrap items-center gap-2 mb-2">
                      <time class="text-xs text-muted-foreground">{post.data.pubDate.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}</time>
                      <span class="text-xs text-muted-foreground">&middot;</span>
                      <span class="text-xs text-muted-foreground">{readingTime(post.body || "")}</span>
                    </div>
                    <h2 class="text-lg font-semibold mb-2 group-hover:text-primary transition-colors duration-200">{post.data.title}</h2>
                    <p class="text-sm text-muted-foreground leading-relaxed mb-4 flex-1">{post.data.description}</p>
                    <div class="flex items-center justify-between">
                      <div class="flex flex-wrap gap-1">
                        {post.data.tags.slice(0, 2).map((tag) => (
                          <span class="inline-flex h-4 items-center rounded-full bg-primary/10 text-primary px-2 text-[9px] font-medium">{tag}</span>
                        ))}
                      </div>
                      <span class="text-xs font-medium text-primary group-hover:underline decoration-primary/30 underline-offset-4">Read &rarr;</span>
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </>
        )}
        {rest.length === 0 && (
          <div class="text-center py-10">
            <p class="text-muted-foreground">More articles coming soon. Stay tuned.</p>
          </div>
        )}
      </div>
    </section>

    <Footer />
  </body>
</html>
