---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import BackgroundEffects from "../components/layout/BackgroundEffects.astro";
import ColorConverter from "../components/tools/ColorConverter.astro";
import ThemeInit from "../components/ui/ThemeInit.astro";
import OfferBanner from "../components/ads/OfferBanner.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Color Converter — Lootpaper</title>
    <meta name="description" content="Convert between HEX, RGB, and HSL color formats instantly. Free, no signup." />
    <meta property="og:title" content="Color Converter — Lootpaper" />
    <meta property="og:description" content="Free HEX, RGB, HSL color converter. No signup." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <ThemeInit />
    <ClientRouter />
  </head>
  <body class="bg-background text-foreground">
    <BackgroundEffects />
    <Header currentPath={Astro.url.pathname} />
    <main class="py-20">
      <div class="container">
        <div class="text-center mb-10">
          <span class="inline-flex h-7 items-center rounded-full border border-primary/20 bg-primary/8 px-3.5 text-xs font-medium text-primary mb-4">Tool</span>
          <h1 class="text-3xl lg:text-4xl font-bold tracking-tight mb-3">Color <span class="gradient-text">Converter</span></h1>
          <p class="text-muted-foreground max-w-lg mx-auto">Convert between HEX, RGB, and HSL color formats with a live preview.</p>
        </div>
        <ColorConverter />
        <OfferBanner />
      </div>
    </main>
    <Footer />
  </body>
</html>
