---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import BackgroundEffects from "../components/layout/BackgroundEffects.astro";
import ThemeInit from "../components/ui/ThemeInit.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>404 — Page Not Found | Lootpaper</title>
    <meta name="description" content="Page not found. Let's get you back on track." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <ThemeInit />
    <ClientRouter />
  </head>
  <body class="bg-background text-foreground">
    <BackgroundEffects />
    <Header currentPath="/404" />

    <section class="py-32 text-center">
      <div class="container">
        <span class="inline-flex h-7 items-center rounded-full border border-primary/20 bg-primary/8 px-3.5 text-xs font-medium text-primary mb-6">404</span>
        <h1 class="text-7xl lg:text-8xl font-bold tracking-tight mb-4 gradient-text">404</h1>
        <p class="text-xl text-muted-foreground mb-2">Page not found</p>
        <p class="text-muted-foreground mb-10 max-w-sm mx-auto">The page you're looking for doesn't exist or has been moved. Let's get you back on track.</p>
        <div class="flex flex-wrap gap-3 justify-center">
          <a href="/" class="btn-primary">Go Home</a>
          <a href="/tools" class="btn-secondary">Browse Tools</a>
        </div>
      </div>
    </section>

    <Footer />
  </body>
</html>
