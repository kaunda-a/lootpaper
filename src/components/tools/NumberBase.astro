<div class="w-full max-w-lg mx-auto">
  <div class="rounded-xl border border-border bg-card p-7">
    <div class="grid gap-4 sm:grid-cols-2 mb-4">
      <div>
        <label class="text-xs font-medium text-muted-foreground mb-1.5 block">From Base</label>
        <select id="from-base" class="flex h-11 w-full rounded-xl border border-input bg-background px-3 py-2 text-sm text-foreground ring-offset-background focus:outline-none focus:ring-2 focus:ring-ring transition-all duration-200">
          <option value="2">Binary (2)</option><option value="8">Octal (8)</option><option value="10" selected>Decimal (10)</option><option value="16">Hex (16)</option>
        </select>
      </div>
      <div>
        <label class="text-xs font-medium text-muted-foreground mb-1.5 block">To Base</label>
        <select id="to-base" class="flex h-11 w-full rounded-xl border border-input bg-background px-3 py-2 text-sm text-foreground ring-offset-background focus:outline-none focus:ring-2 focus:ring-ring transition-all duration-200">
          <option value="2">Binary (2)</option><option value="8">Octal (8)</option><option value="10">Decimal (10)</option><option value="16" selected>Hex (16)</option>
        </select>
      </div>
    </div>
    <input type="text" id="num-input" placeholder="Enter number..." class="flex h-11 w-full rounded-xl border border-input bg-background px-4 py-2 text-sm text-foreground font-mono ring-offset-background placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-ring transition-all duration-200 mb-3" />
    <button id="convert-btn" class="btn-primary h-10 px-5 text-sm mb-3">Convert</button>
    <input id="output" readonly class="flex h-12 w-full rounded-xl border border-input bg-background px-4 py-2 text-sm text-foreground font-mono ring-offset-background focus:outline-none transition-all duration-200" />
  </div>
</div>

<script>
  const fromBase = document.getElementById("from-base");
  const toBase = document.getElementById("to-base");
  const input = document.getElementById("num-input");
  const output = document.getElementById("output");
  const btn = document.getElementById("convert-btn");

  function convert() {
    const val = input.value.trim();
    if (!val) { output.value = ""; return; }
    try {
      const dec = parseInt(val, parseInt(fromBase.value));
      if (isNaN(dec)) { output.value = "Invalid number"; return; }
      output.value = dec.toString(parseInt(toBase.value)).toUpperCase();
    } catch { output.value = "Error"; }
  }

  btn.addEventListener("click", convert);
  fromBase.addEventListener("change", convert);
  toBase.addEventListener("change", convert);
  input.addEventListener("keydown", e => { if (e.key === "Enter") convert(); });
</script>