<div class="w-full max-w-lg mx-auto">
  <div class="rounded-xl border border-border bg-card p-7">
    <div class="flex gap-3 mb-5">
      <select id="version-select" class="flex h-11 w-28 rounded-xl border border-input bg-background px-3 py-2 text-sm text-foreground ring-offset-background focus:outline-none focus:ring-2 focus:ring-ring transition-all duration-200">
        <option value="v4">UUID v4</option><option value="v1">UUID v1</option>
      </select>
      <button id="generate-btn" class="btn-primary h-11 flex-1">Generate UUID</button>
    </div>
    <div class="relative">
      <input id="uuid-output" readonly class="flex h-12 w-full rounded-xl border border-input bg-background px-4 py-2 text-sm text-foreground font-mono tracking-wide text-center pr-12" />
      <button id="copy-btn" class="absolute right-3 top-1/2 -translate-y-1/2 text-xs text-primary hover:underline">Copy</button>
    </div>
    <p id="count" class="text-xs text-muted-foreground text-center mt-3"></p>
  </div>
</div>

<script>
  function uuidV4() { return ([1e7]+-1e3+-4e3+-8e3+-1e11).replace(/[018]/g, c => (c ^ crypto.getRandomValues(new Uint8Array(1))[0] & 15 >> c / 4).toString(16)); }
  function uuidV1() { const d = Date.now(); const h = d.toString(16).padStart(12,"0"); return h.slice(0,8)+"-"+h.slice(8,12)+"-1"+h.slice(12,15)+"-a"+Array.from({length:3},()=>Math.floor(Math.random()*256).toString(16).padStart(2,"0")).join("")+"-"+Array.from({length:6},()=>Math.floor(Math.random()*256).toString(16).padStart(2,"0")).join(""); }

  const sel = document.getElementById("version-select");
  const btn = document.getElementById("generate-btn");
  const out = document.getElementById("uuid-output");
  let c = 0;

  function generate() {
    const fn = sel.value === "v4" ? uuidV4 : uuidV1;
    out.value = fn();
    c++;
    document.getElementById("count").textContent = `Generated ${c} UUID${c > 1 ? "s" : ""} this session`;
  }

  btn.addEventListener("click", generate);
  generate();

  document.getElementById("copy-btn").addEventListener("click", () => {
    navigator.clipboard.writeText(out.value);
    document.getElementById("copy-btn").textContent = "Copied!";
    setTimeout(() => { document.getElementById("copy-btn").textContent = "Copy"; }, 2000);
  });
</script>