<div class="w-full max-w-lg mx-auto">
  <div class="rounded-xl border border-border bg-card p-7">
    <div class="flex gap-3 mb-5">
      <input type="number" id="length-input" value="16" min="4" max="128" class="flex h-11 w-24 rounded-xl border border-input bg-background px-4 py-2 text-sm text-foreground text-center ring-offset-background focus:outline-none focus:ring-2 focus:ring-ring transition-all duration-200" />
      <button id="generate-btn" class="btn-primary h-11 flex-1">Generate Password</button>
    </div>
    <div class="flex flex-wrap gap-4 mb-5 text-sm">
      <label class="flex items-center gap-2 cursor-pointer"><input type="checkbox" id="chk-upper" checked class="accent-primary size-4" /> <span class="text-muted-foreground">A-Z</span></label>
      <label class="flex items-center gap-2 cursor-pointer"><input type="checkbox" id="chk-lower" checked class="accent-primary size-4" /> <span class="text-muted-foreground">a-z</span></label>
      <label class="flex items-center gap-2 cursor-pointer"><input type="checkbox" id="chk-digits" checked class="accent-primary size-4" /> <span class="text-muted-foreground">0-9</span></label>
      <label class="flex items-center gap-2 cursor-pointer"><input type="checkbox" id="chk-symbols" class="accent-primary size-4" /> <span class="text-muted-foreground">!@#$%</span></label>
    </div>
    <div class="relative">
      <input id="password-output" readonly class="flex h-12 w-full rounded-xl border border-input bg-background px-4 py-2 text-lg text-foreground font-mono tracking-wider text-center pr-12" />
      <button id="copy-btn" class="absolute right-3 top-1/2 -translate-y-1/2 text-xs text-primary hover:underline">Copy</button>
    </div>
    <div id="strength" class="mt-3 h-2 rounded-full bg-muted overflow-hidden"><div id="strength-bar" class="h-full rounded-full transition-all duration-300" style="width:0%"></div></div>
  </div>
</div>

<script>
  const len = document.getElementById("length-input");
  const btn = document.getElementById("generate-btn");
  const out = document.getElementById("password-output");
  const bar = document.getElementById("strength-bar");

  function generate() {
    let chars = "";
    if (document.getElementById("chk-upper").checked) chars += "ABCDEFGHIJKLMNOPQRSTUVWXYZ";
    if (document.getElementById("chk-lower").checked) chars += "abcdefghijklmnopqrstuvwxyz";
    if (document.getElementById("chk-digits").checked) chars += "0123456789";
    if (document.getElementById("chk-symbols").checked) chars += "!@#$%^&*()_+-=[]{}|;:,.<>?";
    if (!chars.length) return;

    const length = Math.min(Math.max(parseInt(len.value) || 16, 4), 128);
    let pwd = "";
    for (let i = 0; i < length; i++) pwd += chars[Math.floor(Math.random() * chars.length)];
    out.value = pwd;

    const score = Math.min(length / 128 * 100 + (chars.length / 4) * 25, 100);
    bar.style.width = score + "%";
    bar.style.background = score < 40 ? "#ef4444" : score < 70 ? "#f59e0b" : "#22c55e";
  }

  btn.addEventListener("click", generate);
  document.querySelectorAll("#chk-upper, #chk-lower, #chk-digits, #chk-symbols").forEach(cb => cb.addEventListener("change", generate));
  len.addEventListener("input", generate);
  generate();

  document.getElementById("copy-btn").addEventListener("click", () => {
    navigator.clipboard.writeText(out.value);
    document.getElementById("copy-btn").textContent = "Copied!";
    setTimeout(() => { document.getElementById("copy-btn").textContent = "Copy"; }, 2000);
  });
</script>